{
	"name": "familiar-intellij-themes",
	"displayName": "Familiar IntelliJ Themes",
	"description": "Familiar color themes inspired by IntelliJ IDEA.",
	"author": "jestan <jestannirojan@gmail.com>",
	"publisher": "jestan",
	"version": "0.0.2",
	"preview": true,
	"license": "SEE LICENSE IN LICENSE.txt",
	"engines": {
		"vscode": "^1.45.0"
	},
	"categories": [
		"Themes"
	],
	"keywords": [
		"intellij",
		"darcula",
		"semantic-highlighting"
	],
	"homepage": "https://github.com/jestan/familiar-intellij-themes",
	"repository": {
		"type": "git",
		"url": "https://github.com/jestan/familiar-intellij-themes.git"
	},
	"bugs": {
		"url": "https://github.com/jestan/familiar-intellij-themes/issues"
	},
	"icon": "logo.png",
	"main": "extension.js",
	"activationEvents": [
		"onCommand:familiarJavaThemes.configurationHelper"
	],
	"contributes": {
		"commands": [
			{
				"command": "familiarJavaThemes.configurationHelper",
				"category": "Familiar Java Themes",
				"title": "Configuration Helper"
			}
		],
		"themes": [
			{
				"label": "IntelliJ Light",
				"uiTheme": "vs",
				"path": "./themes/intellij-light-color-theme.json"
			},
			{
				"label": "IntelliJ Dark",
				"uiTheme": "vs-dark",
				"path": "./themes/intellij-dark-color-theme.json"
			}
		]
	}
}